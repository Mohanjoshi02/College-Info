    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        // Smooth scrolling for navigation links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });
        
        // Check if images are loaded and hide notice
        window.addEventListener('load', function() {
            const images = document.querySelectorAll('.gallery-item img');
            let imagesLoaded = 0;
            
            images.forEach(img => {
                if (img.complete && img.naturalHeight !== 0) {
                    imagesLoaded++;
                }
            });
            
            // If at least 3 images loaded successfully, hide the notice
            if (imagesLoaded >= 3) {
                const notice = document.getElementById('imageNotice');
                if (notice) {
                    notice.style.display = 'none';
                }
            }
        });
        
        // Handle image load errors - show placeholder
        document.querySelectorAll('.gallery-item img').forEach(img => {
            img.addEventListener('error', function() {
                this.style.background = 'linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%)';
                this.style.display = 'flex';
                this.style.alignItems = 'center';
                this.style.justifyContent = 'center';
                this.alt = '📸 Image not found - Please add ' + this.src.split('/').pop();
            });
        });
    </script>
