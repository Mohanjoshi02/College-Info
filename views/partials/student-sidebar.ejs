<script>
// ── SPA Navigation ─────────────────────────────────────────────────────────
function initSpaNav() {
  document.querySelectorAll('.spa-link').forEach(link => {
    if (link._spaInit) return;
    link._spaInit = true;
    link.addEventListener('click', async function(e) {
      e.preventDefault();
      const href = this.getAttribute('href');
      await loadPage(href);
    });
  });
}

async function loadPage(href) {
  const mainContent = document.querySelector('.main-content');
  if (!mainContent) { window.location.href = href; return; }

  // Show spinner
  mainContent.style.opacity = '0.5';
  mainContent.style.pointerEvents = 'none';

  try {
    const res = await fetch(href, { headers: { 'X-SPA': '1' } });
    const html = await res.text();

    // Parse and extract .main-content from response
    const parser = new DOMParser();
    const doc = parser.parseFromString(html, 'text/html');
    const newMain = doc.querySelector('.main-content');

    if (newMain) {
      mainContent.innerHTML = newMain.innerHTML;
      // Re-run scripts in new content
      mainContent.querySelectorAll('script').forEach(oldScript => {
        const newScript = document.createElement('script');
        if (oldScript.src) { newScript.src = oldScript.src; }
        else { newScript.textContent = oldScript.textContent; }
        oldScript.parentNode.replaceChild(newScript, oldScript);
      });
      history.pushState({ href }, '', href);
    } else {
      window.location.href = href;
    }
  } catch(err) {
    window.location.href = href;
  }

  mainContent.style.opacity = '1';
  mainContent.style.pointerEvents = '';
  updateActiveLinks();
}

// Handle browser back/forward
window.addEventListener('popstate', function(e) {
  if (e.state && e.state.href) loadPage(e.state.href);
  else loadPage(location.pathname);
});

// ── Dropdown toggles with localStorage persistence ─────────────────────────
function initDropdown(toggleId, bodyId, defaultOpen) {
  const toggle = document.getElementById(toggleId);
  const body   = document.getElementById(bodyId);
  if (!toggle || !body) return;

  const stored = localStorage.getItem('sidebar_' + toggleId);
  const isOpen = stored !== null ? JSON.parse(stored) : defaultOpen;
  if (isOpen) { toggle.classList.add('open'); body.classList.add('open'); }

  toggle.addEventListener('click', () => {
    const opening = !toggle.classList.contains('open');
    toggle.classList.toggle('open');
    body.classList.toggle('open');
    localStorage.setItem('sidebar_' + toggleId, JSON.stringify(opening));
  });
}

initDropdown('csitToggle',      'csitBody',      true);
initDropdown('mechToggle',      'mechBody',      false);
initDropdown('netToggle',       'netBody',       false);
initDropdown('communityToggle', 'communityBody', false);

// ── Active link highlight ──────────────────────────────────────────────────
function updateActiveLinks() {
  const currentPath = window.location.pathname;
  document.querySelectorAll('.nav-link, .branch-link').forEach(link => {
    const href = link.getAttribute('href');
    link.classList.remove('active');
    if (href === currentPath || (href !== '/student' && currentPath.startsWith(href))) {
      link.classList.add('active');
    }
  });
}
updateActiveLinks();
initSpaNav();

// ── Sidebar Search ─────────────────────────────────────────────────────────
const searchInput   = document.getElementById('sidebarSearch');
const searchResults = document.getElementById('searchResults');
const searchableLinks = [
  { text: 'Dashboard',             icon: 'fa-home',             href: '/student' },
  { text: 'Assignments',           icon: 'fa-tasks',            href: '/student/assignments' },
  { text: 'Attendance',            icon: 'fa-calendar-check',   href: '/student/attendance' },
  { text: 'Marks & Grades',        icon: 'fa-chart-bar',        href: '/student/marks' },
  { text: 'Notices',               icon: 'fa-bell',             href: '/student/notices' },
  { text: 'Fee Status',            icon: 'fa-credit-card',      href: '/student/fees' },
  { text: 'Timetable',             icon: 'fa-clock',            href: '/student/timetable' },
  { text: 'Coding Practice',       icon: 'fa-code',             href: '/student/coding' },
  { text: 'Hackathons',            icon: 'fa-trophy',           href: '/student/hackathons' },
  { text: 'Internships',           icon: 'fa-briefcase',        href: '/student/internships' },
  { text: 'Interview Prep',        icon: 'fa-user-tie',         href: '/student/interview' },
  { text: 'Digital Resume',        icon: 'fa-file-alt',         href: '/student/resume' },
  { text: 'Project Showcase',      icon: 'fa-project-diagram',  href: '/student/projects' },
  { text: 'CAD Practice',          icon: 'fa-drafting-compass', href: '/student/cad' },
  { text: 'Design Challenges',     icon: 'fa-lightbulb',        href: '/student/design-challenges' },
  { text: 'Thermal Eng. Quiz',     icon: 'fa-fire',             href: '/student/thermal-quiz' },
  { text: 'Network Simulation',    icon: 'fa-project-diagram',  href: '/student/network-sim' },
  { text: 'Networking Challenges', icon: 'fa-trophy',           href: '/student/net-challenges' },
  { text: 'Network Security',      icon: 'fa-shield-alt',       href: '/student/net-security' },
  { text: 'Project Marketplace',   icon: 'fa-store',            href: '/student/marketplace' },
  { text: 'Alumni Network',        icon: 'fa-user-graduate',    href: '/student/alumni' },
  { text: 'Campus Info',           icon: 'fa-map-marker-alt',   href: '/visitors' },
];

if (searchInput) {
  searchInput.addEventListener('input', () => {
    const q = searchInput.value.trim().toLowerCase();
    if (!q) { searchResults.classList.remove('visible'); return; }
    const filtered = searchableLinks.filter(l => l.text.toLowerCase().includes(q));
    if (!filtered.length) {
      searchResults.innerHTML = '<div class="search-result-item" style="color:#94a3b8;">No results found</div>';
      searchResults.classList.add('visible'); return;
    }
    searchResults.innerHTML = filtered.slice(0,8).map(l =>
      `<a href="${l.href}" class="search-result-item spa-link"><i class="fas ${l.icon}"></i>${l.text}</a>`
    ).join('');
    searchResults.classList.add('visible');
    // Re-bind spa nav on search results
    initSpaNav();
  });

  document.addEventListener('click', e => {
    if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
      searchResults.classList.remove('visible');
    }
  });
}
</script>
