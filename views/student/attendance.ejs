<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Attendance - MIT ADT</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="dashboard-container">
  <%- include('../partials/student-sidebar') %>
  <div class="main-content">
    <%- include('../partials/top-header', { pageTitle: 'Attendance', user, notifications }) %>

    <div class="page-header">
      <div>
        <h1 class="page-title"><i class="fas fa-calendar-check me-2"></i>My Attendance</h1>
        <p class="welcome-text">Track your subject-wise attendance percentage</p>
      </div>
    </div>

    <!-- Warning Banner -->
    <% const lowAttendance = attendance.filter(a => a.percentage < 75); %>
    <% if (lowAttendance.length > 0) { %>
    <div class="attendance-warning">
      <div class="warn-icon"><i class="fas fa-exclamation-triangle"></i></div>
      <div>
        <div class="warn-title">⚠ Attendance Below Required Level</div>
        <div class="warn-msg">You have <strong><%= lowAttendance.length %></strong> subject(s) below 75%. Attend more classes to avoid detainment.</div>
      </div>
    </div>
    <% } %>

    <!-- Overall Stats -->
    <% const totalPct = attendance.length ? (attendance.reduce((s,a) => s + (a.percentage||0), 0) / attendance.length) : 0; %>
    <div class="row g-3 mb-4">
      <div class="col-md-3 col-6">
        <div class="stat-card" style="border-top-color:var(--primary-light);">
          <div class="stat-icon">📚</div>
          <div class="stat-number"><%= attendance.length %></div>
          <div class="stat-label">Subjects</div>
        </div>
      </div>
      <div class="col-md-3 col-6">
        <div class="stat-card" style="border-top-color:<%= totalPct>=75?'#10b981':'#ef4444' %>;">
          <div class="stat-icon"><%= totalPct>=75?'✅':'⚠️' %></div>
          <div class="stat-number" style="color:<%= totalPct>=75?'#10b981':'#ef4444' %>;"><%= totalPct.toFixed(0) %>%</div>
          <div class="stat-label">Overall Avg</div>
        </div>
      </div>
      <div class="col-md-3 col-6">
        <div class="stat-card" style="border-top-color:#10b981;">
          <div class="stat-icon">🟢</div>
          <div class="stat-number" style="color:#10b981;"><%= attendance.filter(a=>a.percentage>=75).length %></div>
          <div class="stat-label">Good Standing</div>
        </div>
      </div>
      <div class="col-md-3 col-6">
        <div class="stat-card" style="border-top-color:#ef4444;">
          <div class="stat-icon">🔴</div>
          <div class="stat-number" style="color:#ef4444;"><%= lowAttendance.length %></div>
          <div class="stat-label">Low Attendance</div>
        </div>
      </div>
    </div>

    <!-- Attendance Table -->
    <div class="card">
      <div class="card-header green"><i class="fas fa-calendar-check"></i> Subject-wise Attendance</div>
      <div class="card-body p-0">
        <% if (attendance.length === 0) { %>
          <div class="text-center py-5"><i class="fas fa-calendar-times" style="font-size:3rem;color:var(--gray-300);display:block;margin-bottom:12px;"></i><p style="color:var(--gray-500);">No attendance records found.</p></div>
        <% } else { %>
        <div class="table-responsive">
          <table class="table" style="margin:0;">
            <thead>
              <tr>
                <th>Subject</th>
                <th>Total Classes</th>
                <th>Attended</th>
                <th>Percentage</th>
                <th>Progress</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% attendance.forEach(r => {
                const pct = r.percentage || 0; const low = pct < 75;
              %>
              <tr style="<%= low ? 'background:rgba(239,68,68,0.03)' : '' %>">
                <td><strong style="color:var(--gray-800);"><%= r.subject %></strong></td>
                <td style="color:var(--gray-600);"><%= r.totalClasses %></td>
                <td style="color:var(--gray-600);"><%= r.attendedClasses %></td>
                <td class="<%= low ? 'low-attendance' : '' %>" style="font-weight:700;"><%= pct.toFixed(1) %>%</td>
                <td style="min-width:120px;">
                  <div class="progress">
                    <div class="progress-bar <%= pct>=75?'success':pct>=50?'warning':'danger' %>" style="width:<%= Math.min(pct,100) %>%;"></div>
                  </div>
                </td>
                <td>
                  <% if (low) { %>
                    <span class="badge badge-danger"><i class="fas fa-exclamation-triangle me-1"></i>Low</span>
                  <% } else { %>
                    <span class="badge badge-success"><i class="fas fa-check me-1"></i>Good</span>
                  <% } %>
                  <% if (r.supportFile) { %>
                    <a href="/uploads/<%= r.supportFile %>" target="_blank" class="btn btn-outline btn-sm ms-1"><i class="fas fa-eye"></i></a>
                  <% } %>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
