<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Design Challenges - MIT ADT</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="dashboard-container">
  <%- include('../partials/student-sidebar') %>
  <div class="main-content">
    <%- include('../partials/top-header', { pageTitle: 'Design Challenges', user, notifications }) %>
    <div class="page-header">
      <div>
        <h1 class="page-title"><i class="fas fa-lightbulb me-2"></i>Design Challenges</h1>
        <p class="welcome-text">Mechanical Engineering — Real-world design problem solving</p>
      </div>
      <span class="badge badge-teal" style="font-size:0.9rem;padding:8px 14px;">Mechanical Branch</span>
    </div>
    <div class="row g-3">
      <% const challenges = [
        { title: 'Bridge Load Simulation', desc: 'Design a bridge structure to withstand 5-ton load using minimum material.', deadline: 'Apr 15', difficulty: 'Hard' },
        { title: 'Ergonomic Seating Design', desc: 'Create a chair design optimised for 8-hour usage in an office environment.', deadline: 'Apr 20', difficulty: 'Medium' },
        { title: 'Heat Exchanger Optimisation', desc: 'Design a compact heat exchanger for a given thermal specification.', deadline: 'Apr 25', difficulty: 'Hard' },
        { title: 'Gear Train Assembly', desc: 'Design a 3-stage gear train for 10:1 speed reduction.', deadline: 'Apr 30', difficulty: 'Medium' },
      ]; %>
      <% challenges.forEach(c => { %>
      <div class="col-md-6">
        <div class="problem-card" style="border-radius:var(--radius-lg);">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;">
            <h6 style="font-weight:700;color:var(--gray-800);margin:0;"><%= c.title %></h6>
            <span class="badge <%= c.difficulty==='Hard'?'badge-danger':c.difficulty==='Medium'?'badge-warning':'badge-success' %>"><%= c.difficulty %></span>
          </div>
          <p style="color:var(--gray-600);font-size:0.875rem;margin-bottom:12px;"><%= c.desc %></p>
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <span style="font-size:0.78rem;color:var(--danger);"><i class="fas fa-calendar-times me-1"></i>Deadline: <%= c.deadline %></span>
            <a href="#" class="btn btn-primary btn-sm"><i class="fas fa-upload me-1"></i>Submit</a>
          </div>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
