<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Hackathons - MIT ADT</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="dashboard-container">
  <%- include('../partials/student-sidebar') %>
  <div class="main-content">
    <div class="page-header">
      <div>
        <h1 class="page-title"><i class="fas fa-trophy me-2"></i>Hackathons & Competitions</h1>
        <p class="welcome-text">Compete, build, and win!</p>
      </div>
      <form method="POST" action="/logout">
        <button type="submit" class="logout-btn"><i class="fas fa-sign-out-alt me-1"></i>Logout</button>
      </form>
    </div>

    <% const hackathons = [
      { name: 'Smart India Hackathon 2025', theme: 'AI & Sustainability', date: 'April 15, 2025', link: 'https://sih.gov.in', status: 'Open' },
      { name: 'HackMIT 2025', theme: 'Future of Education', date: 'May 10, 2025', link: 'https://hackmit.org', status: 'Open' },
      { name: 'Google Solution Challenge', theme: 'UN Sustainable Goals', date: 'March 30, 2025', link: 'https://developers.google.com/community/gdsc-solution-challenge', status: 'Closing Soon' },
      { name: 'Flipkart Grid 6.0', theme: 'E-Commerce Innovation', date: 'June 1, 2025', link: 'https://unstop.com', status: 'Upcoming' },
      { name: 'CodeFest VNIT', theme: 'Open Innovation', date: 'April 20, 2025', link: 'https://unstop.com', status: 'Open' },
      { name: 'HackWithInfy', theme: 'Digital Transformation', date: 'May 25, 2025', link: 'https://infosys.com', status: 'Upcoming' }
    ]; %>

    <div class="row g-3">
      <% hackathons.forEach(h => { %>
      <div class="col-md-4">
        <div class="module-card" style="border-top:4px solid #1e3a8a;">
          <div class="d-flex justify-content-between align-items-start mb-2">
            <div class="card-title"><%= h.name %></div>
            <span class="badge <%= h.status === 'Open' ? 'badge-success' : h.status === 'Closing Soon' ? 'badge-danger' : 'badge-info' %>">
              <%= h.status %>
            </span>
          </div>
          <div class="card-meta"><i class="fas fa-lightbulb me-1"></i><%= h.theme %></div>
          <div class="card-meta"><i class="fas fa-calendar me-1"></i><%= h.date %></div>
          <a href="<%= h.link %>" target="_blank" class="btn-outline mt-3" style="font-size:0.82rem;">
            <i class="fas fa-external-link-alt me-1"></i>Register Now
          </a>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
