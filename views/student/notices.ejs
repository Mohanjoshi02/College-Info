<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Notices - MIT ADT</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="dashboard-container">
  <%- include('../partials/student-sidebar') %>
  <div class="main-content">
    <%- include('../partials/top-header', { pageTitle: 'Notices', user, notifications }) %>

    <div class="page-header">
      <div>
        <h1 class="page-title"><i class="fas fa-bell me-2"></i>Notice Board</h1>
        <p class="welcome-text">Stay updated with the latest announcements</p>
      </div>
      <span class="badge badge-warning" style="font-size:0.9rem;padding:8px 16px;"><%= notices.length %> Notice<%= notices.length !== 1 ? 's' : '' %></span>
    </div>

    <% if (notices.length === 0) { %>
      <div class="card"><div class="card-body text-center py-5"><i class="fas fa-bell-slash" style="font-size:3rem;color:var(--gray-300);display:block;margin-bottom:12px;"></i><p style="color:var(--gray-500);">No notices posted yet.</p></div></div>
    <% } else { %>
      <% notices.forEach((n, i) => { %>
      <div class="card mb-3" style="border-left:4px solid var(--warning);animation:fadeIn <%= 0.1 + i*0.05 %>s ease-out;">
        <div class="card-body" style="padding:20px 24px;">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;">
            <div style="flex:1;">
              <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
                <div style="width:36px;height:36px;border-radius:50%;background:var(--warning-bg);display:flex;align-items:center;justify-content:center;color:var(--warning);font-size:1rem;flex-shrink:0;">
                  <i class="fas fa-bullhorn"></i>
                </div>
                <h5 style="font-weight:700;color:var(--gray-800);margin:0;"><%= n.title %></h5>
              </div>
              <p style="color:var(--gray-600);font-size:0.9rem;margin:0;line-height:1.6;padding-left:46px;"><%= n.message %></p>
            </div>
            <div style="text-align:right;flex-shrink:0;">
              <div style="font-size:0.75rem;color:var(--gray-400);"><i class="fas fa-clock me-1"></i><%= new Date(n.createdAt).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) %></div>
              <div style="font-size:0.72rem;color:var(--gray-400);margin-top:2px;"><%= new Date(n.createdAt).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'}) %></div>
            </div>
          </div>
        </div>
      </div>
      <% }); %>
    <% } %>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
