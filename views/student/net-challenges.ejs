<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Networking Challenges - MIT ADT</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="dashboard-container">
  <%- include('../partials/student-sidebar') %>
  <div class="main-content">
    <%- include('../partials/top-header', { pageTitle: 'Networking Challenges', user, notifications }) %>

    <div class="page-header">
      <div>
        <h1 class="page-title"><i class="fas fa-trophy me-2"></i>Networking Challenges</h1>
        <p class="welcome-text">Compete, solve, and earn badges in networking problem sets</p>
      </div>
      <span class="badge badge-primary" style="font-size:0.9rem;padding:8px 14px;">Networking Branch</span>
    </div>

    <!-- Leaderboard + Active Challenges -->
    <div class="row g-4 mb-4">
      <div class="col-md-8">
        <div class="card h-100">
          <div class="card-header" style="background:linear-gradient(135deg,#1a2f6e,#3b6cf6);"><i class="fas fa-tasks"></i> Active Challenges</div>
          <div class="card-body p-0">
            <% const challenges = [
              { title: 'Subnet Solver Sprint',       desc: 'Solve 10 subnetting problems in under 15 minutes.', deadline: 'Apr 10', pts: 200, difficulty: 'Medium', category: 'Subnetting' },
              { title: 'Protocol Match Quiz',        desc: 'Match 20 networking protocols to their ports and layers.', deadline: 'Apr 12', pts: 150, difficulty: 'Easy', category: 'Protocols' },
              { title: 'Packet Tracer Chase',        desc: 'Fix a broken 3-router Packet Tracer topology in under 20 min.', deadline: 'Apr 15', pts: 300, difficulty: 'Hard', category: 'Simulation' },
              { title: 'OSI Layer Relay',            desc: 'Answer 5 questions each about each OSI layer in relay format.', deadline: 'Apr 18', pts: 250, difficulty: 'Medium', category: 'OSI Model' },
              { title: 'Cisco IOS Command Drill',    desc: 'Identify the correct IOS command for 20 given tasks.', deadline: 'Apr 22', pts: 200, difficulty: 'Hard', category: 'Cisco IOS' },
            ]; %>
            <% challenges.forEach(c => { %>
            <div style="padding:14px 18px;border-bottom:1px solid var(--gray-100);display:flex;align-items:center;gap:14px;">
              <div style="flex:1;">
                <div style="font-weight:700;color:var(--gray-800);font-size:0.9rem;margin-bottom:2px;"><%= c.title %></div>
                <div style="font-size:0.78rem;color:var(--gray-500);margin-bottom:6px;"><%= c.desc %></div>
                <div style="display:flex;gap:8px;align-items:center;">
                  <span class="badge <%= c.difficulty==='Easy'?'badge-success':c.difficulty==='Medium'?'badge-warning':'badge-danger' %>"><%= c.difficulty %></span>
                  <span style="font-size:0.72rem;color:var(--gray-400);"><i class="fas fa-tag me-1"></i><%= c.category %></span>
                  <span style="font-size:0.72rem;color:var(--danger);"><i class="fas fa-calendar-times me-1"></i><%= c.deadline %></span>
                </div>
              </div>
              <div style="text-align:center;flex-shrink:0;">
                <div style="font-size:1.1rem;font-weight:800;color:var(--primary);"><%= c.pts %></div>
                <div style="font-size:0.65rem;color:var(--gray-400);text-transform:uppercase;">PTS</div>
              </div>
              <button class="btn btn-primary btn-sm"><i class="fas fa-bolt me-1"></i>Attempt</button>
            </div>
            <% }); %>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card h-100">
          <div class="card-header amber"><i class="fas fa-crown"></i> Leaderboard</div>
          <div class="card-body p-0">
            <% const leaders = [
              { rank: 1, name: 'Arjun Mehta', pts: 1820, badge: '👑' },
              { rank: 2, name: 'Priya Joshi', pts: 1650, badge: '🥈' },
              { rank: 3, name: 'Rahul Patil', pts: 1480, badge: '🥉' },
              { rank: 4, name: 'Sneha Kulkarni', pts: 1320, badge: '⭐' },
              { rank: 5, name: 'Vivek Desai', pts: 1120, badge: '⭐' },
            ]; %>
            <% leaders.forEach(l => { %>
            <div style="padding:12px 16px;border-bottom:1px solid var(--gray-100);display:flex;align-items:center;gap:12px;">
              <div style="width:28px;text-align:center;font-size:1.1rem;"><%= l.badge %></div>
              <div style="flex:1;font-weight:600;font-size:0.88rem;color:var(--gray-800);"><%= l.name %></div>
              <div style="font-weight:700;color:var(--primary);font-size:0.9rem;"><%= l.pts.toLocaleString() %> pts</div>
            </div>
            <% }); %>
            <div style="padding:16px;text-align:center;color:var(--gray-400);font-size:0.8rem;">
              <i class="fas fa-user me-1"></i>Your rank: Not yet ranked
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Badge Gallery -->
    <div class="card">
      <div class="card-header"><i class="fas fa-medal"></i> Earn Badges</div>
      <div class="card-body">
        <div class="row g-3">
          <% const badges = [
            { name: 'Subnet Ace',   icon: 'fa-calculator', color: '#3b6cf6', earned: false },
            { name: 'Protocol Pro', icon: 'fa-network-wired', color: '#10b981', earned: false },
            { name: 'CCNA Ready',   icon: 'fa-certificate', color: '#f59e0b', earned: false },
            { name: 'OSI Master',   icon: 'fa-layer-group', color: '#7c3aed', earned: false },
            { name: 'Firewall Guru',icon: 'fa-shield-alt',  color: '#ef4444', earned: false },
            { name: 'Speed Demon',  icon: 'fa-bolt',        color: '#0d9488', earned: false },
          ]; %>
          <% badges.forEach(b => { %>
          <div class="col-6 col-md-2">
            <div style="text-align:center;padding:16px 8px;opacity:<%= b.earned?1:0.4 %>;">
              <div style="width:56px;height:56px;border-radius:50%;background:<%= b.color %>20;display:flex;align-items:center;justify-content:center;margin:0 auto 8px;">
                <i class="fas <%= b.icon %>" style="color:<%= b.color %>;font-size:1.3rem;"></i>
              </div>
              <div style="font-size:0.75rem;font-weight:700;color:var(--gray-600);"><%= b.name %></div>
              <div style="font-size:0.65rem;color:var(--gray-400);">Locked</div>
            </div>
          </div>
          <% }); %>
        </div>
      </div>
    </div>

  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
