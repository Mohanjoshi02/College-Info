<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Student Dashboard - MIT ADT</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="dashboard-container">
  <%- include('../partials/student-sidebar') %>
  <div class="main-content">
    <%- include('../partials/top-header', { pageTitle: 'Dashboard', user, notifications }) %>

    <!-- Attendance Warning -->
    <% const lowAttendance = attendance.filter(a => a.percentage < 75); %>
    <% if (lowAttendance.length > 0) { %>
    <div class="attendance-warning">
      <div class="warn-icon"><i class="fas fa-exclamation-triangle"></i></div>
      <div>
        <div class="warn-title">⚠ Attendance Warning</div>
        <div class="warn-msg"><%= lowAttendance.length %> subject(s) below 75% — <%= lowAttendance.map(a => a.subject).join(', ') %></div>
      </div>
    </div>
    <% } %>

    <!-- Stats -->
    <div class="row g-3 mb-4">
      <div class="col-6 col-md-3">
        <div class="stat-card" style="border-top-color:#3b6cf6;">
          <div class="stat-icon">📋</div>
          <div class="stat-number"><%= assignments.length %></div>
          <div class="stat-label">Assignments</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card" style="border-top-color:#10b981;">
          <div class="stat-icon">📅</div>
          <div class="stat-number"><%= attendance.length %></div>
          <div class="stat-label">Subjects Tracked</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card" style="border-top-color:#f59e0b;">
          <div class="stat-icon">📣</div>
          <div class="stat-number"><%= notices.length %></div>
          <div class="stat-label">Notices</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card" style="border-top-color:#10b981;">
          <div class="stat-icon">✅</div>
          <div class="stat-number" style="color:#10b981;font-size:1.4rem;">Paid</div>
          <div class="stat-label">Fee Status</div>
        </div>
      </div>
    </div>

    <!-- Next Class of the Day Widget -->
    <div id="nextClassBanner" class="mb-4"></div>

    <div class="row g-3 mb-4">
      <!-- Quick Links -->
      <div class="col-md-4">
        <div class="card h-100">
          <div class="card-header"><i class="fas fa-bolt"></i> Quick Access</div>
          <div class="card-body p-3">
            <div class="d-grid gap-2">
              <a href="/student/assignments" class="btn btn-primary"><i class="fas fa-tasks"></i> My Assignments</a>
              <a href="/student/attendance"  class="btn btn-primary" style="background:linear-gradient(135deg,#065f46,#10b981);"><i class="fas fa-calendar-check"></i> My Attendance</a>
              <a href="/student/marks"       class="btn btn-primary" style="background:linear-gradient(135deg,#4c1d95,#7c3aed);"><i class="fas fa-chart-bar"></i> Marks & SGPA</a>
              <a href="/student/timetable"   class="btn btn-primary" style="background:linear-gradient(135deg,#134e4a,#0d9488);"><i class="fas fa-clock"></i> Timetable</a>
              <a href="/student/marketplace" class="btn btn-primary" style="background:linear-gradient(135deg,#92400e,#f59e0b);"><i class="fas fa-store"></i> Project Marketplace</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Recent Assignments -->
      <div class="col-md-4">
        <div class="card card-assignments h-100">
          <div class="card-header"><i class="fas fa-tasks"></i> Recent Assignments</div>
          <div class="card-body p-0">
            <% if (assignments.length === 0) { %>
              <p class="text-center text-muted py-4">No assignments yet.</p>
            <% } else { %>
              <% assignments.slice(0,4).forEach(a => {
                const due = new Date(a.dueDate); const overdue = due < new Date();
              %>
              <div style="padding:12px 18px;border-bottom:1px solid var(--gray-100);display:flex;justify-content:space-between;align-items:center;">
                <div>
                  <div style="font-weight:600;font-size:0.85rem;color:var(--gray-800)"><%= a.title %></div>
                  <div style="font-size:0.75rem;color:var(--gray-500)"><%= a.subject %></div>
                </div>
                <span class="badge <%= overdue ? 'badge-danger' : 'badge-success' %>"><%= overdue ? 'Overdue' : 'Active' %></span>
              </div>
              <% }); %>
              <div style="padding:10px 18px;text-align:center;">
                <a href="/student/assignments" style="font-size:0.8rem;color:var(--primary-light);text-decoration:none;font-weight:600;">View All →</a>
              </div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Recent Notices -->
      <div class="col-md-4">
        <div class="card card-notices h-100">
          <div class="card-header amber"><i class="fas fa-bell"></i> Latest Notices</div>
          <div class="card-body p-0">
            <% if (notices.length === 0) { %>
              <p class="text-center text-muted py-4">No notices.</p>
            <% } else { %>
              <% notices.slice(0,4).forEach(n => { %>
              <div style="padding:12px 18px;border-bottom:1px solid var(--gray-100);">
                <div style="font-weight:600;font-size:0.85rem;color:var(--gray-800)"><i class="fas fa-circle" style="color:#f59e0b;font-size:0.5rem;margin-right:6px;"></i><%= n.title %></div>
                <div style="font-size:0.75rem;color:var(--gray-500);margin-top:2px;"><%= n.message.substring(0,60) %><%= n.message.length > 60 ? '...' : '' %></div>
              </div>
              <% }); %>
              <div style="padding:10px 18px;text-align:center;">
                <a href="/student/notices" style="font-size:0.8rem;color:#f59e0b;text-decoration:none;font-weight:600;">View All →</a>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <!-- Attendance Summary -->
    <div class="card card-attendance">
      <div class="card-header green"><i class="fas fa-calendar-check"></i> Attendance Overview</div>
      <div class="card-body">
        <% if (attendance.length === 0) { %>
          <p class="text-center text-muted">No attendance records yet.</p>
        <% } else { %>
        <div class="row g-3">
          <% attendance.slice(0,6).forEach(r => {
            const pct = r.percentage || 0; const low = pct < 75;
          %>
          <div class="col-md-4">
            <div style="background:var(--gray-50);border-radius:var(--radius-md);padding:14px;border:1px solid var(--gray-200);">
              <div style="font-weight:600;font-size:0.85rem;color:var(--gray-800);margin-bottom:6px;"><%= r.subject.substring(0,28) %><%= r.subject.length>28?'...':'' %></div>
              <div class="progress mb-2">
                <div class="progress-bar <%= pct>=75?'success':'danger' %>" style="width:<%= pct %>%;"></div>
              </div>
              <div style="display:flex;justify-content:space-between;align-items:center;">
                <span style="font-size:0.78rem;color:var(--gray-500);"><%= r.attendedClasses %>/<%= r.totalClasses %> classes</span>
                <span class="badge <%= low ? 'badge-danger' : 'badge-success' %>"><%= pct.toFixed(0) %>%</span>
              </div>
            </div>
          </div>
          <% }); %>
        </div>
        <div class="text-center mt-3">
          <a href="/student/attendance" class="btn btn-outline btn-sm"><i class="fas fa-eye"></i> View Full Attendance</a>
        </div>
        <% } %>
      </div>
    </div>

  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
// ── Next Class of the Day ────────────────────────────────────────────────────
const timetable = <%- JSON.stringify(timetable) %>;
const dayNames = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
const now = new Date();
const todayName = dayNames[now.getDay()];
const nowMins = now.getHours() * 60 + now.getMinutes();

function parseTime(t) {
  if (!t) return null;
  const m = t.match(/(\d+):(\d+)\s*(AM|PM)/i);
  if (!m) return null;
  let h = parseInt(m[1]); const min = parseInt(m[2]);
  if (m[3].toUpperCase() === 'PM' && h !== 12) h += 12;
  if (m[3].toUpperCase() === 'AM' && h === 12) h = 0;
  return h * 60 + min;
}

const todayClasses = timetable.filter(t => t.day === todayName);
let nextClass = null, minDiff = Infinity;
todayClasses.forEach(c => {
  const t = parseTime(c.time);
  if (t !== null && t > nowMins && (t - nowMins) < minDiff) {
    minDiff = t - nowMins; nextClass = c;
  }
});

const banner = document.getElementById('nextClassBanner');
if (nextClass) {
  const hrs = Math.floor(minDiff/60), mins = minDiff % 60;
  banner.innerHTML = `
    <div class="next-class-widget">
      <div class="next-class-icon"><i class="fas fa-chalkboard-teacher"></i></div>
      <div class="next-class-info">
        <div class="next-class-tag">NEXT CLASS TODAY</div>
        <div class="next-class-subject">${nextClass.subject}</div>
        <div class="next-class-meta">
          <span><i class="fas fa-clock me-1"></i>${nextClass.time}</span>
          <span><i class="fas fa-user-tie me-1"></i>${nextClass.faculty}</span>
          <span><i class="fas fa-door-open me-1"></i>${nextClass.room}</span>
          <span class="next-class-countdown"><i class="fas fa-hourglass-half me-1"></i>In ${hrs > 0 ? hrs + 'h ' : ''}${mins}m</span>
        </div>
      </div>
      <a href="/student/timetable" class="next-class-link">View Full Schedule <i class="fas fa-arrow-right ms-1"></i></a>
    </div>`;
} else if (todayClasses.length > 0) {
  banner.innerHTML = `<div class="next-class-done"><i class="fas fa-moon me-2"></i>All classes done for today! Great work, ${todayName}.</div>`;
}
</script>
</body>
</html>
