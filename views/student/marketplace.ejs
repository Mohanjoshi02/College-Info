<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Industry Project Marketplace - MIT ADT</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="dashboard-container">
  <%- include('../partials/student-sidebar') %>
  <div class="main-content">
    <%- include('../partials/top-header', { pageTitle: 'Project Marketplace', user, notifications }) %>

    <div class="page-header">
      <div>
        <h1 class="page-title"><i class="fas fa-store me-2"></i>Industry Project Marketplace</h1>
        <p class="welcome-text">Real projects from companies and startups — apply and get mentored</p>
      </div>
      <span class="badge badge-primary" style="font-size:0.9rem;padding:8px 16px;"><%= projects.length %> Project<%= projects.length !== 1 ? 's' : '' %> Available</span>
    </div>

    <% if (typeof success !== 'undefined' && success) { %>
      <div class="alert alert-success"><i class="fas fa-check-circle"></i> Application submitted! Awaiting faculty approval.</div>
    <% } %>

    <% if (projects.length === 0) { %>
      <div class="card">
        <div class="card-body text-center py-5">
          <i class="fas fa-store" style="font-size:3rem;color:var(--gray-300);display:block;margin-bottom:12px;"></i>
          <p style="color:var(--gray-500);">No projects posted yet. Check back soon!</p>
        </div>
      </div>
    <% } else { %>
    <div class="row g-3">
      <% projects.forEach(p => {
        const myApplication = p.applicants && p.applicants.find(a => a.student && a.student.toString() === userId);
        const deadline = new Date(p.deadline);
        const isExpired = deadline < new Date();
      %>
      <div class="col-md-6 col-lg-4">
        <div class="project-card">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;">
            <div class="project-company"><i class="fas fa-building me-1"></i><%= p.companyName %></div>
            <span class="badge <%= isExpired ? 'badge-danger' : 'badge-success' %>"><%= isExpired ? 'Closed' : 'Open' %></span>
          </div>
          <div class="project-title"><%= p.projectTitle %></div>
          <div class="project-desc"><%= p.description %></div>
          <div class="project-skills">
            <% (p.requiredSkills || []).forEach(skill => { %>
              <span class="skill-tag"><%= skill %></span>
            <% }); %>
          </div>
          <div class="project-deadline mb-3">
            <i class="fas fa-calendar-times"></i> Deadline: <strong><%= deadline.toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) %></strong>
          </div>
          <% if (myApplication) { %>
            <div style="background:var(--info-bg);border:1px solid #bfdbfe;border-radius:var(--radius-md);padding:10px 14px;text-align:center;">
              <% if (myApplication.status === 'approved') { %>
                <span style="color:var(--success);font-weight:700;"><i class="fas fa-check-circle me-1"></i>Application Approved!</span>
              <% } else if (myApplication.status === 'rejected') { %>
                <span style="color:var(--danger);font-weight:700;"><i class="fas fa-times-circle me-1"></i>Application Rejected</span>
              <% } else { %>
                <span style="color:var(--primary);font-weight:700;"><i class="fas fa-hourglass-half me-1"></i>Application Pending — Awaiting approval</span>
              <% } %>
            </div>
          <% } else if (!isExpired) { %>
            <form method="POST" action="/student/marketplace/<%= p._id %>/apply">
              <button type="submit" class="btn btn-primary btn-block"><i class="fas fa-paper-plane me-1"></i> Apply Now</button>
            </form>
          <% } else { %>
            <button class="btn btn-outline btn-block" disabled style="opacity:0.5;cursor:not-allowed;">Deadline Passed</button>
          <% } %>
        </div>
      </div>
      <% }); %>
    </div>
    <% } %>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
