<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Notices - MIT ADT</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="dashboard-container">
  <%- include('../partials/faculty-sidebar') %>
  <div class="main-content">
    <%- include('../partials/top-header', { pageTitle: 'Manage Notices', user, notifications: [] }) %>
    <div class="page-header">
      <div>
        <h1 class="page-title"><i class="fas fa-bell me-2"></i>Manage Notices</h1>
        <p class="welcome-text">Post and manage student notices</p>
      </div>
    </div>

    <% if (success) { %>
      <div class="alert alert-success"><i class="fas fa-check-circle me-2"></i>Notice posted successfully!</div>
    <% } %>

    <!-- Create Notice -->
    <div class="card">
      <div class="card-header"><i class="fas fa-plus"></i>Post New Notice</div>
      <div class="card-body">
        <form method="POST" action="/admin/notices">
          <div class="form-group">
            <label class="form-label">Notice Title</label>
            <input type="text" class="form-control" name="title" required placeholder="Enter notice title">
          </div>
          <div class="form-group">
            <label class="form-label">Message</label>
            <textarea class="form-control" name="message" rows="4" required placeholder="Enter notice message..."></textarea>
          </div>
          <button type="submit" class="btn-success"><i class="fas fa-paper-plane me-1"></i>Post Notice</button>
        </form>
      </div>
    </div>

    <!-- Notices List -->
    <div class="card">
      <div class="card-header"><i class="fas fa-list"></i>All Notices (<%= notices.length %>)</div>
      <div class="card-body">
        <% if (notices.length === 0) { %>
          <p class="text-center text-muted py-3">No notices posted yet.</p>
        <% } else { %>
          <% notices.forEach(n => { %>
          <div class="alert alert-info d-flex justify-content-between align-items-start mb-3">
            <div>
              <h6 class="mb-1"><strong><%= n.title %></strong></h6>
              <p class="mb-1" style="font-size:0.9rem;"><%= n.message %></p>
              <small class="text-muted"><i class="fas fa-clock me-1"></i><%= new Date(n.createdAt).toLocaleDateString() %></small>
            </div>
            <form method="POST" action="/admin/notices/<%= n._id %>/delete" onsubmit="return confirm('Delete this notice?')" class="ms-3">
              <button type="submit" class="btn-danger"><i class="fas fa-trash"></i></button>
            </form>
          </div>
          <% }); %>
        <% } %>
      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
