<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Student Reports - MIT ADT</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="dashboard-container">
  <%- include('../partials/faculty-sidebar') %>
  <div class="main-content">
    <div class="page-header">
      <div>
        <h1 class="page-title"><i class="fas fa-exclamation-circle me-2"></i>Student Problem Reports</h1>
        <p class="welcome-text">Review and resolve student issues</p>
      </div>
      <form method="POST" action="/logout">
        <button type="submit" class="logout-btn"><i class="fas fa-sign-out-alt me-1"></i>Logout</button>
      </form>
    </div>

    <div class="row g-3 mb-4">
      <div class="col-md-4"><div class="stat-card">
        <div class="stat-number"><%= reports.length %></div>
        <div class="stat-label">Total Reports</div>
      </div></div>
      <div class="col-md-4"><div class="stat-card">
        <div class="stat-number" style="color:#f59e0b;"><%= reports.filter(r=>r.status==='Pending').length %></div>
        <div class="stat-label">Pending</div>
      </div></div>
      <div class="col-md-4"><div class="stat-card">
        <div class="stat-number" style="color:#10b981;"><%= reports.filter(r=>r.status==='Resolved').length %></div>
        <div class="stat-label">Resolved</div>
      </div></div>
    </div>

    <div class="card">
      <div class="card-header"><i class="fas fa-list"></i>All Reports</div>
      <div class="card-body">
        <% if (reports.length === 0) { %>
          <p class="text-center text-muted py-3">No reports submitted yet.</p>
        <% } else { %>
        <div class="table-responsive">
          <table class="table">
            <thead><tr><th>Student</th><th>Category</th><th>Description</th><th>Date</th><th>Status</th><th>Action</th></tr></thead>
            <tbody>
              <% reports.forEach(r => { %>
              <tr>
                <td><strong><%= r.studentName %></strong></td>
                <td><span class="badge badge-info"><%= r.category %></span></td>
                <td style="max-width:220px;"><%= r.description %></td>
                <td><%= new Date(r.date).toLocaleDateString() %></td>
                <td><span class="badge badge-<%= r.status === 'Pending' ? 'pending' : 'resolved' %>"><%= r.status %></span></td>
                <td>
                  <form method="POST" action="/admin/reports/<%= r._id %>/status" style="display:flex;gap:6px;">
                    <select name="status" class="form-control" style="padding:4px 8px;font-size:0.82rem;width:auto;">
                      <option value="Pending" <%= r.status==='Pending'?'selected':'' %>>Pending</option>
                      <option value="Resolved" <%= r.status==='Resolved'?'selected':'' %>>Resolved</option>
                    </select>
                    <button type="submit" class="btn-success" style="padding:4px 10px;font-size:0.82rem;">Update</button>
                  </form>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
