<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Student Marks - MIT ADT Faculty</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="dashboard-container">
  <%- include('../partials/faculty-sidebar') %>
  <div class="main-content">
    <%- include('../partials/top-header', { pageTitle: 'Student Marks', user, notifications: [] }) %>

    <div class="page-header">
      <div>
        <h1 class="page-title"><i class="fas fa-chart-bar me-2"></i>Manage Student Marks</h1>
        <p class="welcome-text">Select a subject first — then enter marks for each student</p>
      </div>
    </div>

    <% if (typeof success !== 'undefined' && success) { %>
      <div class="alert alert-success"><i class="fas fa-check-circle"></i> Marks saved successfully!</div>
    <% } %>

    <!-- Step 1: Select Subject & Exam Type -->
    <div class="card mb-4">
      <div class="card-header purple"><i class="fas fa-filter"></i> Step 1 — Select Subject & Exam</div>
      <div class="card-body">
        <div class="form-row">
          <div class="form-col">
            <label class="form-label">Subject</label>
            <select id="subjectSelect" class="form-control form-select">
              <option value="">-- Select Subject --</option>
              <% SUBJECTS.forEach(s => { %>
                <option value="<%= s %>"><%= s %></option>
              <% }); %>
            </select>
          </div>
          <div class="form-col">
            <label class="form-label">Exam Type</label>
            <select id="examTypeSelect" class="form-control form-select">
              <option value="Mid-Semester I">Mid-Semester Exam I</option>
              <option value="Mid-Semester II">Mid-Semester Exam II</option>
              <option value="End-Semester">End-Semester Exam</option>
            </select>
          </div>
          <div class="form-col" style="flex:0 0 180px;display:flex;align-items:flex-end;">
            <button class="btn btn-primary btn-block" onclick="loadStudents()">
              <i class="fas fa-users me-2"></i>Load Students
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Step 2: Student Marks Entry Table (shown after subject select) -->
    <div id="marksEntrySection" style="display:none;">
      <div class="card mb-4">
        <div class="card-header" style="background:linear-gradient(135deg,#059669,#10b981);">
          <i class="fas fa-table"></i> Step 2 — Enter Marks for All Students
          <span id="subjectBadge" class="badge ms-2" style="background:rgba(255,255,255,0.25);font-size:0.8rem;"></span>
        </div>
        <div class="card-body p-0">
          <form method="POST" action="/admin/marks/bulk" id="bulkMarksForm">
            <input type="hidden" name="subject" id="hiddenSubject">
            <input type="hidden" name="examType" id="hiddenExamType">
            <div class="table-responsive">
              <table class="table" style="margin:0;" id="studentsMarksTable">
                <thead>
                  <tr>
                    <th style="width:40px;">#</th>
                    <th>Student Name</th>
                    <th style="text-align:center;width:160px;">
                      Marks Obtained
                      <div style="font-size:0.7rem;font-weight:400;color:rgba(255,255,255,0.7);" id="maxMarksLabel">(out of 30)</div>
                    </th>
                    <th style="text-align:center;width:140px;">Total Marks</th>
                    <th style="text-align:center;width:100px;">Grade</th>
                  </tr>
                </thead>
                <tbody id="studentMarksBody">
                  <!-- filled by JS -->
                </tbody>
              </table>
            </div>
            <div style="padding:16px 20px;border-top:1px solid var(--gray-100);display:flex;gap:12px;align-items:center;">
              <button type="submit" class="btn btn-primary">
                <i class="fas fa-save me-2"></i>Save All Marks
              </button>
              <button type="button" class="btn btn-outline" onclick="document.getElementById('marksEntrySection').style.display='none'">
                <i class="fas fa-times me-1"></i>Cancel
              </button>
              <span style="margin-left:auto;font-size:0.82rem;color:var(--gray-500);">
                <i class="fas fa-info-circle me-1"></i>Grade is auto-calculated on save
              </span>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- Existing Marks Table — grouped by subject -->
    <div class="card">
      <div class="card-header"><i class="fas fa-list"></i> All Marks Entered (<%= marks.length %> records)</div>
      <div class="card-body p-0">
        <% if (marks.length === 0) { %>
          <div class="text-center py-5">
            <i class="fas fa-clipboard-list" style="font-size:3rem;color:var(--gray-300);display:block;margin-bottom:12px;"></i>
            <p style="color:var(--gray-500);">No marks entered yet. Select a subject above to begin.</p>
          </div>
        <% } else { %>
        <%
          // Group by subject
          const grouped = {};
          marks.forEach(m => {
            if (!grouped[m.subject]) grouped[m.subject] = [];
            grouped[m.subject].push(m);
          });
        %>
        <% Object.entries(grouped).forEach(([subject, subjectMarks]) => { %>
          <div style="border-bottom:2px solid var(--gray-100);">
            <div style="padding:12px 18px;background:var(--gray-50);display:flex;align-items:center;gap:10px;">
              <i class="fas fa-book" style="color:var(--primary-light);"></i>
              <span style="font-weight:700;color:var(--gray-800)"><%= subject %></span>
              <span class="badge badge-primary ms-1"><%= subjectMarks.length %> students</span>
            </div>
            <table class="table" style="margin:0;">
              <thead><tr><th>Student</th><th style="text-align:center;">Internal</th><th style="text-align:center;">Final</th><th style="text-align:center;">Total</th><th style="text-align:center;">Grade</th></tr></thead>
              <tbody>
                <% subjectMarks.forEach(m => {
                  const gradeClass = m.grade === 'O' ? 'grade-O' : m.grade === 'A+' ? 'grade-Ap' : m.grade === 'A' ? 'grade-A' : m.grade === 'B+' ? 'grade-Bp' : m.grade === 'B' ? 'grade-B' : m.grade === 'C' ? 'grade-C' : 'grade-F';
                %>
                <tr>
                  <td><strong><%= m.studentName || 'Unknown' %></strong></td>
                  <td style="text-align:center;"><%= m.internalMarks %>/50</td>
                  <td style="text-align:center;"><%= m.finalMarks %>/100</td>
                  <td style="text-align:center;font-weight:700;color:var(--primary);"><%= m.totalMarks %>/150</td>
                  <td style="text-align:center;"><div class="grade-badge <%= gradeClass %>" style="margin:0 auto;"><%= m.grade %></div></td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% }); %>
        <% } %>
      </div>
    </div>

  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
// All students passed from server
const ALL_STUDENTS = <%- JSON.stringify(students) %>;

const examMaxMarks = {
  'Mid-Semester I':  30,
  'Mid-Semester II': 30,
  'End-Semester':    70
};

function getGrade(pct) {
  if (pct >= 90) return 'O';
  if (pct >= 80) return 'A+';
  if (pct >= 70) return 'A';
  if (pct >= 60) return 'B+';
  if (pct >= 50) return 'B';
  if (pct >= 40) return 'C';
  return 'F';
}

function loadStudents() {
  const subject  = document.getElementById('subjectSelect').value;
  const examType = document.getElementById('examTypeSelect').value;

  if (!subject) { alert('Please select a subject first.'); return; }

  const maxMarks = examMaxMarks[examType] || 30;

  // Update hidden inputs
  document.getElementById('hiddenSubject').value  = subject;
  document.getElementById('hiddenExamType').value = examType;
  document.getElementById('subjectBadge').textContent = subject + ' — ' + examType;
  document.getElementById('maxMarksLabel').textContent = '(out of ' + maxMarks + ')';

  // Build student rows
  const tbody = document.getElementById('studentMarksBody');
  tbody.innerHTML = ALL_STUDENTS.map((s, i) => `
    <tr>
      <td style="color:var(--gray-400);font-size:0.8rem;">${i+1}</td>
      <td>
        <strong style="color:var(--gray-800);">${s.name}</strong>
        <input type="hidden" name="students[${i}][id]"   value="${s._id}">
        <input type="hidden" name="students[${i}][name]" value="${s.name}">
      </td>
      <td style="text-align:center;">
        <div style="display:flex;align-items:center;justify-content:center;gap:6px;">
          <input type="number" name="students[${i}][marks]" class="form-control marks-input"
            min="0" max="${maxMarks}" placeholder="0-${maxMarks}" required
            style="width:90px;text-align:center;"
            data-idx="${i}" data-max="${maxMarks}"
            oninput="updateRow(this)">
          <span style="color:var(--gray-400);font-size:0.8rem;">/${maxMarks}</span>
        </div>
      </td>
      <td style="text-align:center;" id="total-${i}"><span style="color:var(--gray-400);">—</span></td>
      <td style="text-align:center;" id="grade-${i}"><span style="color:var(--gray-400);">—</span></td>
    </tr>
  `).join('');

  document.getElementById('marksEntrySection').style.display = 'block';
  document.getElementById('marksEntrySection').scrollIntoView({ behavior: 'smooth' });
}

function updateRow(input) {
  const idx = input.dataset.idx;
  const max = parseInt(input.dataset.max);
  const val = parseInt(input.value) || 0;
  const pct = Math.round((val / max) * 100);
  const grade = getGrade(pct);
  const gradeColors = { 'O':'#059669','A+':'#0d9488','A':'#3b6cf6','B+':'#7c3aed','B':'#f59e0b','C':'#f97316','F':'#ef4444' };

  document.getElementById('total-'+idx).innerHTML =
    `<strong style="color:var(--primary);">${val}<span style="color:var(--gray-400);font-weight:400;">/${max}</span></strong>`;

  document.getElementById('grade-'+idx).innerHTML =
    `<span style="background:${gradeColors[grade]}20;color:${gradeColors[grade]};padding:4px 12px;border-radius:20px;font-weight:700;font-size:0.82rem;">${grade}</span>`;
}
</script>
</body>
</html>
