<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Assignments - MIT ADT</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="dashboard-container">
  <%- include('../partials/faculty-sidebar') %>
  <div class="main-content">
    <%- include('../partials/top-header', { pageTitle: 'Assignments', user, notifications: [] }) %>
    <div class="page-header">
      <div>
        <h1 class="page-title"><i class="fas fa-tasks me-2"></i>Manage Assignments</h1>
        <p class="welcome-text">Create assignments and review student submissions</p>
      </div>
    </div>

    <% if (success) { %>
      <div class="alert alert-success"><i class="fas fa-check-circle me-2"></i>Assignment added successfully!</div>
    <% } %>

    <!-- Create Assignment Form -->
    <div class="card">
      <div class="card-header"><i class="fas fa-plus"></i>Create New Assignment</div>
      <div class="card-body">
        <form method="POST" action="/admin/assignments" enctype="multipart/form-data">
          <div class="form-row">
            <div class="form-col">
              <label class="form-label">Subject</label>
              <select class="form-control" name="subject" required>
                <option value="">-- Select Subject --</option>
                <% SUBJECTS.forEach(s => { %>
                  <option value="<%= s %>"><%= s %></option>
                <% }); %>
              </select>
            </div>
            <div class="form-col">
              <label class="form-label">Assignment Title</label>
              <input type="text" class="form-control" name="title" required placeholder="Enter title">
            </div>
          </div>
          <div class="form-row">
            <div class="form-col">
              <label class="form-label">Description</label>
              <textarea class="form-control" name="description" rows="3" required placeholder="Assignment details..."></textarea>
            </div>
            <div class="form-col">
              <label class="form-label">Due Date</label>
              <input type="date" class="form-control" name="dueDate" required>
              <label class="form-label mt-3">Upload PDF (optional)</label>
              <input type="file" class="form-control" name="pdfFile" accept=".pdf">
              <small class="text-muted">PDF files only, max 10MB</small>
            </div>
          </div>
          <button type="submit" class="btn-success mt-2"><i class="fas fa-plus me-1"></i>Add Assignment</button>
        </form>
      </div>
    </div>

    <!-- Assignments List -->
    <div class="card">
      <div class="card-header"><i class="fas fa-list"></i>All Assignments (<%= assignments.length %>)</div>
      <div class="card-body">
        <% if (assignments.length === 0) { %>
          <p class="text-center text-muted py-3">No assignments created yet.</p>
        <% } else { %>
        <div class="table-responsive">
          <table class="table">
            <thead><tr><th>Subject</th><th>Title</th><th>Due Date</th><th>Submissions</th><th>PDF</th><th>Action</th></tr></thead>
            <tbody>
              <% assignments.forEach(a => {
                const aSubmissions = (submissions || []).filter(s => s.assignment && s.assignment.toString() === a._id.toString());
              %>
              <tr>
                <td><strong><%= a.subject %></strong></td>
                <td><%= a.title %></td>
                <td><%= new Date(a.dueDate).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) %></td>
                <td>
                  <a href="/admin/assignments/<%= a._id %>/submissions" class="btn btn-outline btn-sm">
                    <i class="fas fa-inbox me-1"></i><%= aSubmissions.length %> submitted
                  </a>
                </td>
                <td>
                  <% if (a.pdfFile) { %>
                    <a href="/uploads/<%= a.pdfFile %>" target="_blank" class="btn btn-outline btn-sm">
                      <i class="fas fa-file-pdf me-1"></i>View
                    </a>
                  <% } else { %><span class="text-muted">—</span><% } %>
                </td>
                <td>
                  <form method="POST" action="/admin/assignments/<%= a._id %>/delete" onsubmit="return confirm('Delete?')">
                    <button type="submit" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></button>
                  </form>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
