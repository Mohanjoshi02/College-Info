<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Timetable - MIT ADT</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="dashboard-container">
  <%- include('../partials/faculty-sidebar') %>
  <div class="main-content">
    <div class="page-header">
      <div>
        <h1 class="page-title"><i class="fas fa-clock me-2"></i>Timetable Management</h1>
        <p class="welcome-text">Add and update class schedules</p>
      </div>
      <form method="POST" action="/logout">
        <button type="submit" class="logout-btn"><i class="fas fa-sign-out-alt me-1"></i>Logout</button>
      </form>
    </div>

    <% if (success) { %>
      <div class="alert alert-success"><i class="fas fa-check-circle me-2"></i>Timetable updated!</div>
    <% } %>

    <div class="card">
      <div class="card-header"><i class="fas fa-plus"></i>Add / Update Timetable Entry</div>
      <div class="card-body">
        <form method="POST" action="/admin/timetable">
          <div class="form-row">
            <div class="form-col">
              <label class="form-label">Day</label>
              <select class="form-control" name="day" required>
                <option value="">-- Select Day --</option>
                <% ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'].forEach(d => { %>
                  <option value="<%= d %>"><%= d %></option>
                <% }); %>
              </select>
            </div>
            <div class="form-col">
              <label class="form-label">Subject</label>
              <select class="form-control" name="subject" required>
                <option value="">-- Select Subject --</option>
                <% SUBJECTS.forEach(s => { %>
                  <option value="<%= s %>"><%= s %></option>
                <% }); %>
              </select>
            </div>
          </div>
          <div class="form-row">
            <div class="form-col">
              <label class="form-label">Faculty Name</label>
              <input type="text" class="form-control" name="faculty" required placeholder="e.g. Dr. Sharma">
            </div>
            <div class="form-col">
              <label class="form-label">Room</label>
              <input type="text" class="form-control" name="room" required placeholder="e.g. A101">
            </div>
            <div class="form-col">
              <label class="form-label">Time</label>
              <input type="text" class="form-control" name="time" placeholder="e.g. 9:00 AM">
            </div>
          </div>
          <button type="submit" class="btn-success mt-2"><i class="fas fa-save me-1"></i>Save Entry</button>
        </form>
      </div>
    </div>

    <div class="card">
      <div class="card-header"><i class="fas fa-table"></i>Current Timetable</div>
      <div class="card-body">
        <% const days = ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
           days.forEach(day => {
             const entries = timetable.filter(t => t.day === day);
             if (entries.length > 0) { %>
          <h6 class="mb-2 mt-3"><span class="day-badge"><%= day %></span></h6>
          <div class="table-responsive mb-3">
            <table class="table">
              <thead><tr><th>Time</th><th>Subject</th><th>Faculty</th><th>Room</th><th>Action</th></tr></thead>
              <tbody>
                <% entries.forEach(e => { %>
                <tr>
                  <td><%= e.time || '—' %></td>
                  <td><%= e.subject %></td>
                  <td><%= e.faculty %></td>
                  <td><%= e.room %></td>
                  <td>
                    <form method="POST" action="/admin/timetable/<%= e._id %>/delete" onsubmit="return confirm('Delete entry?')">
                      <button type="submit" class="btn-danger"><i class="fas fa-trash"></i></button>
                    </form>
                  </td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } }); %>
      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
